---
import BaseLayout from './BaseLayout.astro';
import { site } from '../site';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pageTitle = `${title} — ${site.name}`;
---

<BaseLayout title={pageTitle} description={`${title} мобильного приложения «${site.name}».`}>
  <article class="legal-page section">
    <div class="container legal-container">
      <header class="legal-header">
        <p class="section-eyebrow">Документы</p>
        <h1>{title}</h1>
        <p class="legal-meta">
          Приложение «{site.name}» ({site.packageId}) · обновлено {site.legalUpdated}
        </p>
      </header>
      <div class="legal-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .legal-container {
    max-width: 42rem;
  }

  .legal-header {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--ink-100);
  }

  .legal-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
  }

  .legal-meta {
    color: var(--ink-500);
    font-size: 0.95rem;
    margin: 0;
  }

  .legal-content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
