---
import { screenshots } from '../site';

const base = import.meta.env.BASE_URL;
---

<section class="section screenshots" id="screenshots">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">Интерфейс</p>
      <h2 class="section-title">Три главных раздела</h2>
      <p class="section-lead">
        План, Сад и Растения — всё под рукой на одном экране.
      </p>
    </header>
    <ul class="screenshots-grid">
      {screenshots.map((shot) => (
        <li>
          <article class="screenshot-card">
            <div class="screenshot-visual">
              <img
                src={`${base}${shot.image}`}
                alt={`Экран раздела «${shot.title}»`}
                width="260"
                height="498"
                loading="lazy"
                decoding="async"
              />
            </div>
            <h3>{shot.title}</h3>
            <p>{shot.caption}</p>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .screenshots-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }

  .screenshot-card {
    text-align: center;
  }

  .screenshot-card h3 {
    font-size: 1.15rem;
    margin-top: 1.25rem;
  }

  .screenshot-card p {
    margin: 0;
    color: var(--ink-500);
    font-size: 0.95rem;
  }

  .screenshot-visual {
    margin-inline: auto;
    width: min(100%, 260px);
  }

  .screenshot-visual img {
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 40px rgba(26, 31, 27, 0.18));
  }
</style>
