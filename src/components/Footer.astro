---
import { site } from '../site';
import RustoreQr from './RustoreQr.astro';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="brand-wordmark footer-wordmark">{site.name}</span>
      <p class="footer-tagline">{site.tagline}</p>
    </div>
    <nav class="footer-nav" aria-label="Навигация по сайту">
      <a href={`${base}guide/`}>Руководство пользователя</a>
      <a href={`${base}privacy/`}>Политика конфиденциальности</a>
      <a href={`${base}terms/`}>Пользовательское соглашение</a>
      <a href={`mailto:${site.supportEmail}`}>{site.supportEmail}</a>
    </nav>
    <div class="footer-download">
      <RustoreQr size={176} caption="RuStore" simple />
    </div>
    <p class="footer-copy">
      © {year} «{site.name}». Доступно в RuStore, скоро в App Store.
    </p>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface-sunken);
    border-top: 1px solid var(--ink-100);
    padding: 3rem 0 2rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem 2rem;
    align-items: start;
  }

  .footer-brand {
    grid-column: 1;
  }

  .footer-nav {
    grid-column: 1;
  }

  .footer-download {
    grid-column: 2;
    grid-row: 1 / span 2;
    justify-self: end;
  }

  .footer-download :global(.rustore-qr__caption) {
    color: var(--ink-500);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .footer-copy {
    grid-column: 1 / -1;
  }

  .footer-wordmark {
    font-size: 1.5rem;
    color: var(--brand-600);
  }

  .footer-tagline {
    margin: 0.25rem 0 0;
    color: var(--ink-500);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
  }

  .footer-nav a {
    font-weight: 600;
    text-decoration: none;
  }

  .footer-copy {
    margin: 0;
    color: var(--ink-500);
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .footer-brand,
    .footer-nav,
    .footer-download,
    .footer-copy {
      grid-column: 1;
      grid-row: auto;
    }

    .footer-download {
      justify-self: center;
    }

    .footer-nav {
      justify-content: center;
    }
  }
</style>
