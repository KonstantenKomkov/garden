---
import { site } from '../site';

const base = import.meta.env.BASE_URL;
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="hero-badges">
        <a class="hero-badge hero-badge--link" href={site.stores.rustore} rel="noopener noreferrer">
          Скачать в RuStore
        </a>
        <span class="hero-badge">Скоро в App Store</span>
      </p>
      <img
        class="hero-wordmark"
        src={`${base}images/sad_wordmark.png`}
        alt={site.name}
        width="220"
        height="72"
      />
      <p class="hero-tagline">{site.tagline}</p>
      <p class="hero-lead">{site.description}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={`${base}#features`}>Узнать больше</a>
        <a class="btn btn-secondary" href={`mailto:${site.supportEmail}`}>Написать в поддержку</a>
      </div>
    </div>
    <div class="hero-visual">
      <img
        class="hero-phone"
        src={`${base}images/screenshots/hero.png`}
        alt="Экран создания сада в приложении"
        width="280"
        height="536"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 4.5rem 0 5rem;
    color: #fff;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, var(--hero-top) 0%, var(--hero-mid) 45%, var(--hero-bottom) 100%);
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 85% 20%, rgba(168, 213, 181, 0.25), transparent 55%),
      radial-gradient(ellipse 50% 40% at 10% 80%, rgba(224, 138, 60, 0.12), transparent 50%);
  }

  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1.25rem;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.12);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-badge--link {
    color: inherit;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .hero-badge--link:hover {
    background: rgba(255, 255, 255, 0.22);
    color: #fff;
  }

  .hero-wordmark {
    filter: brightness(0) invert(1);
    margin-bottom: 0.5rem;
  }

  .hero-tagline {
    margin: 0 0 1rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
  }

  .hero-lead {
    max-width: 32rem;
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 1.75rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero .btn-secondary {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.25);
    box-shadow: none;
  }

  .hero .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
  }

  .hero-visual {
    margin-inline: auto;
    width: min(100%, 280px);
  }

  .hero-phone {
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 24px 60px rgba(0, 0, 0, 0.35));
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-lead {
      margin-inline: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-badges {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
    }
  }
</style>
